# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/supporthub
DB_USER=postgres
DB_PASSWORD=postgres

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis123@localhost:6379
REDIS_PASSWORD=redis123

# ─── JWT (OBRIGATÓRIO — gere com: openssl rand -base64 64) ───────────────────
# NUNCA reutilize o mesmo valor em JWT_SECRET, JWT_REFRESH_SECRET ou NEXTAUTH_SECRET
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── NextAuth (OBRIGATÓRIO — gere com: openssl rand -base64 32) ──────────────
# DEVE ser diferente de JWT_SECRET e JWT_REFRESH_SECRET
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ─── URLs ─────────────────────────────────────────────────────────────────────
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
API_URL=http://localhost:3001

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── E-mail (SMTP) ────────────────────────────────────────────────────────────
# Exemplos: Gmail (smtp.gmail.com:587), Mailtrap (sandbox.smtp.mailtrap.io:587)
# Resend (smtp.resend.com:465), Brevo/Sendinblue (smtp-relay.brevo.com:587)
# Se não configurado, emails são ignorados silenciosamente
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Support Hub <noreply@supporthub.com>"
