{
  "name": "@support-hub/database",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "scripts": {
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev --name init",
    "db:migrate:prod": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:seed": "dotenv -e ../../.env -- bun prisma/seed.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "prisma": "^5.14.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/bcryptjs": "^2.4.6",
    "dotenv-cli": "^7.4.2"
  }
}
